generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum TaskPriority {
  low
  medium
  high
}

enum SuggestionKind {
  category
  tag
}

model Task {
  id                  String         @id @default(cuid())
  title               String         @db.VarChar(140)
  description         String?        @db.VarChar(2000)
  priority            TaskPriority
  status              TaskStatus
  dueDate             DateTime?
  classificationKind  SuggestionKind?
  classificationValue String?        @db.VarChar(64)
  parentTaskId        String?
  parentTask          Task?          @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  subtasks            Task[]         @relation("TaskSubtasks")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([parentTaskId])
  @@index([status, priority, dueDate])
  @@map("tasks")
}
