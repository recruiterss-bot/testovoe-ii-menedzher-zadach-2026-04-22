# -----------------------------
# App
# -----------------------------
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1

# -----------------------------
# Database
# -----------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_task_manager

# -----------------------------
# AI provider and model routing
# -----------------------------
# Baseline freeze date: 2026-04-22
# openai | mock
AI_PROVIDER_DEFAULT=openai

# Primary model for all AI scenarios (US-3..US-6)
AI_MODEL_PRIMARY=gpt-4
# Optional per-lane overrides:
# AI_MODEL_ECONOMY=gpt-4
# AI_MODEL_QUALITY=gpt-4

# -----------------------------
# AI reliability and latency
# -----------------------------
AI_TIMEOUT_MS=20000
AI_RETRY_COUNT=1
AI_IDEMPOTENCY_TTL_HOURS=24

# Output limits per scenario
AI_MAX_OUTPUT_TOKENS_US3=120
AI_MAX_OUTPUT_TOKENS_US5=140
AI_MAX_OUTPUT_TOKENS_US4=500
AI_MAX_OUTPUT_TOKENS_US6=350

# Optional pricing overrides per 1M tokens (USD)
AI_PRICE_INPUT_PER_MTOK_USD=30
AI_PRICE_OUTPUT_PER_MTOK_USD=60

# -----------------------------
# AI quality/cost gate budget
# -----------------------------
# USD budget for 1000 mixed AI requests in demo profile
AI_COST_BUDGET_PER_1000_USD=40.00

# -----------------------------
# Provider credentials
# -----------------------------
OPENAI_API_KEY=
